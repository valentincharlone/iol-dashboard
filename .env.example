# Credenciales de tu cuenta en InvertirOnLine
IOL_USERNAME=tu@email.com
IOL_PASSWORD=tu_contraseña_iol

# Credenciales para entrar al dashboard (las elegís vos, no tienen que ser las de IOL)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=tu_contraseña_dashboard

# NextAuth — generá un secret con: openssl rand -base64 32
NEXTAUTH_SECRET=cambia_esto_por_un_secret_real
NEXTAUTH_URL=http://localhost:3000
